{
  "expo": {
    "name": "GoDelivery Courier",
    "slug": "godelivery-courier",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.supportingbases.godelivery.courier",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O GoDelivery precisa acessar sua localização para rastrear entregas em tempo real.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "O GoDelivery precisa acessar sua localização em background para notificar o empresário sobre sua chegada.",
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.supportingbases.godelivery.courier",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O GoDelivery precisa acessar sua localização para rastrear entregas em tempo real.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      ["expo-notifications"]
    ]
  }
}
