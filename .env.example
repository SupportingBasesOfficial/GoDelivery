# ============================================================
# GoDelivery — Variáveis de Ambiente (Exemplo)
# Copie para .env e preencha com valores reais do Supabase/Stripe
# ============================================================

# --- Supabase Cloud (obrigatório) ---
# Crie projeto em https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Stripe (obrigatório para cobrança) ---
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Sentry (opcional, error tracking) ---
# https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=https://... sentry.io /...
SENTRY_ORG=seu-org
SENTRY_PROJECT=godelivery-web

# --- Vercel / Build ---
# Desabilita validação de env em CI (já configurado no vercel.json)
SKIP_ENV_VALIDATION=true
